# ── Polymarket Wallet (required) ──────────────────────────────────────
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_PRIVATE_KEY=

# ── Seren Gateway (required) ─────────────────────────────────────────
SEREN_API_KEY=

# ── ZKP2P Peer Onramp (required for fiat deposit step) ──────────────
# See: https://github.com/zkp2p/zkp2p-skills#environment-variables
#
# PRIVATE_KEY        — Base wallet private key (use same as POLYMARKET_PRIVATE_KEY)
# ZKP2P_API_KEY      — ZKP2P gating service key (contact ZKP2P team or dev portal)
# WISE_API_TOKEN     — Wise personal API token (for autonomous onramp via Wise)
# VENMO_COOKIES      — Venmo session cookies (for semi-autonomous onramp via Venmo)
#
# Pick ONE payment method (Wise recommended for full autonomy):
PRIVATE_KEY=
ZKP2P_API_KEY=
WISE_API_TOKEN=
# VENMO_COOKIES=
