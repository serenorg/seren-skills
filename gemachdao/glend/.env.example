# Required
AGENT_PRIVATE_KEY=            # Wallet private key as a 32-byte hex string starting with 0x (never commit!)

# Optional — defaults to Pharos Testnet
GLEND_CHAIN_ID=688688         # 688688 (Pharos), 1 (Ethereum), 8453 (Base)
GLEND_RPC_URL=                # Override default RPC URL
GLEND_POOL_ADDRESS=           # Override default pool/comptroller address
