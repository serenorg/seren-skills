# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# CEREBRAS_API_KEY=xxx

# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# LINE_CHANNEL_SECRET=xxx
# LINE_CHANNEL_ACCESS_TOKEN=xxx

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Tempo MPP (optional) ─────────────────
# GCLAW_TEMPO_ENABLED=true
# GCLAW_TEMPO_RPC_URL=https://rpc.tempo.xyz
# GCLAW_TEMPO_MAX_PAYMENT_AMOUNT=1000000

# ── Venture Architect live deployment (optional overrides) ──
# Gclaw ships with built-in public RPC defaults for Ethereum, Arbitrum,
# and Base so venture deployment can work out of the box. Set these only
# if you want to override them with your own endpoint later.
# GCLAW_ETHEREUM_RPC_URL=https://your-ethereum-rpc.example
# GCLAW_ARBITRUM_RPC_URL=https://your-arbitrum-rpc.example
# GCLAW_BASE_RPC_URL=https://your-base-rpc.example
# GCLAW_VENTURE_RPC_URL=https://your-fallback-evm-rpc.example

# ── Timezone ──────────────────────────────
TZ=Asia/Tokyo
