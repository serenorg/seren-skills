# Seren API key. Obtain from Seren Desktop login or
# https://docs.serendb.com/skills.md. Required for all publisher
# calls (Perplexity research, Claude inference, SerenDB persistence,
# Google Drive sharing).
SEREN_API_KEY=

# 1Password Service Account token. The skill shells out to the `op`
# CLI to read the Salesforce login item. Generate the SA in 1Password
# admin (one-time, operator-side), grant it read-only access to the
# vault below, then paste the token here. Treat this value as a
# credential — never commit it.
OP_SERVICE_ACCOUNT_TOKEN=

# Name of the 1Password vault holding the Salesforce login item.
# The Service Account above must have read access to this vault.
OP_VAULT=PK Salesforce Skill

# Name of the 1Password item inside the vault. The item must carry
# `username`, `password`, and a TOTP field (the rolling 6-digit MFA
# code). The skill never logs these fields and never persists them
# to disk.
OP_ITEM=PK Salesforce
