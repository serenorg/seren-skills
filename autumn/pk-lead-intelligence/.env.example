# Seren API key. Required for every publisher call this skill makes
# (perplexity, seren-models, google-drive, seren-cron, seren-db).
#
# Resolution order (the skill walks these on every run):
#
#   1. Seren Desktop — leave SEREN_API_KEY empty. The desktop runtime
#      injects API_KEY for you.
#   2. Claude Cowork (desktop Claude app) — Settings > Connectors >
#      Add Custom Connector > URL: https://mcp.serendb.com/mcp.
#      Cowork carries the session; no .env entry needed.
#   3. Claude Code (CLI) — install the same hosted MCP via:
#        claude mcp add --scope user --transport http seren \
#            https://mcp.serendb.com/mcp
#      Then paste the session key the MCP issues into SEREN_API_KEY
#      below if you also need cron-host access.
#   4. Cold-start auto-register — if none of the above is set, the
#      skill calls POST https://api.serendb.com/auth/agent on its
#      first run and writes the returned key here automatically. A
#      one-line warning is emitted on stderr. Jill on Cowork never
#      sees an error.
#   5. Locked-down host — register manually and paste:
#        curl -sS -X POST https://api.serendb.com/auth/agent \
#            -H 'Content-Type: application/json' \
#            -d '{"name":"pk-lead-intelligence"}'
#      Copy .data.agent.api_key into SEREN_API_KEY below.
#
# Do NOT register a second account if a key already exists for your
# team — duplicate registrations issue $0-balance keys that override
# your funded one. The cold-start auto-register only fires when this
# variable is empty AND no .env on disk carries it AND no API_KEY is
# in env. See SKILL.md > API Key Setup.
SEREN_API_KEY=

# Salesforce credentials. Two paths, tried in this order:
#
# PATH A — env vars (works on consumer 1Password / no 1Password at
# all). Set all three. The skill computes the rolling 6-digit MFA
# code locally from the base32 seed using pyotp. Issue #795.
#
#   SF_USERNAME=jill@your-company.com
#   SF_PASSWORD=<your-salesforce-password>
#   SF_TOTP_SECRET=<base32-seed-from-MFA-setup>
#
# Get SF_TOTP_SECRET from an existing 1Password item (edit the
# one-time-password field, reveal the secret) or from Salesforce's
# MFA setup screen ("Can't scan? Use this secret key"). It's the
# long base32 string, NOT the rolling 6-digit code. Set all three or
# none — half-set is rejected at runtime.
SF_USERNAME=
SF_PASSWORD=
SF_TOTP_SECRET=

# PATH B — 1Password Business Service Account (requires Business or
# Teams plan; consumer plans do NOT have Service Accounts). Only
# used when SF_USERNAME / SF_PASSWORD / SF_TOTP_SECRET above are all
# empty. Generate the Service Account in 1Password admin, grant
# read-only access to the vault below, then paste the token here.
# Treat this value as a credential — never commit it.
OP_SERVICE_ACCOUNT_TOKEN=

# Name of the 1Password vault holding the Salesforce login item.
# Used only on PATH B.
OP_VAULT=PK Salesforce Skill

# Name of the 1Password item inside the vault. The item must carry
# `username`, `password`, and a TOTP field (the rolling 6-digit MFA
# code). Used only on PATH B. The skill never logs these fields and
# never persists them to disk.
OP_ITEM=PK Salesforce
