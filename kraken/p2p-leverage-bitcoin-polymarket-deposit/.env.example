# ── Kraken API (required) ─────────────────────────────────────────────
# Create at: kraken.com → Settings → API → Create Key
# Enable: Query Funds, Deposit Funds, Trade, Withdraw Funds
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── Polymarket Wallet (required) ─────────────────────────────────────
# Find at: polymarket.com/wallet
POLYMARKET_WALLET_ADDRESS=

# ── Seren Gateway (required) ─────────────────────────────────────────
SEREN_API_KEY=
