# prophet-arb-bot environment template.
SEREN_API_KEY=
# Optional: pre-supplied Privy JWT. If set, the agent skips the OTP flow
# entirely and trusts the caller to keep the JWT fresh. Useful when the
# bounty-runner has just refreshed in the same machine.
PROPHET_SESSION_TOKEN=

# Polymarket CLOB credentials. Required when execution_mode=delta_neutral
# (the first-run default). Without these the live hedger fails closed with
# reason=polymarket_creds_missing. POLY_PRIVATE_KEY may be replaced by
# WALLET_PRIVATE_KEY if your wallet env already exposes that name.
POLY_PRIVATE_KEY=
POLY_API_KEY=
POLY_PASSPHRASE=
POLY_SECRET=
